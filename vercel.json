{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/admin/billing/cron",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/billing/cron", 
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/billing/sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/sms/cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/dunning",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/recurring-billing",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/bank-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/hse-mark-overdue",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/hse-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/maintenance-reminders",
      "schedule": "0 13 * * *"
    }
  ],
  
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-Requested-With, Content-Type, Authorization"
        }
      ]
    }
  ],
  
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/dashboard",
      "permanent": false
    }
  ],
  
  "rewrites": [
    {
      "source": "/api/billing/:path*",
      "destination": "/api/admin/billing/:path*"
    }
  ]
}
